{
  "info": {
    "name": "ERASM API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@erasm.com\",\n  \"password\": \"Admin@123\",\n  \"role\": \"ADMIN\",\n  \"fullName\": \"System Admin\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@erasm.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Skills",
      "item": [
        {
          "name": "List Skills",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/skills" }
        },
        {
          "name": "Add Skill",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Java\"\n}" },
            "url": "{{baseUrl}}/skills"
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "List Employees",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/employees" }
        },
        {
          "name": "Add Skill to Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"skillId\": 1,\n  \"level\": \"ADVANCED\",\n  \"yearsOfExperience\": 5\n}" },
            "url": "{{baseUrl}}/employees/1/skills"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Healthcare Portal\",\n  \"clientName\": \"Acme Health\",\n  \"startDate\": \"2026-07-01\",\n  \"endDate\": \"2026-12-31\",\n  \"technologyStack\": \"Java,Spring Boot,React\",\n  \"budget\": 500000\n}"
            },
            "url": "{{baseUrl}}/projects"
          }
        },
        {
          "name": "List Projects",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/projects" }
        }
      ]
    },
    {
      "name": "Resource Requests",
      "item": [
        {
          "name": "Create Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"projectId\": 1,\n  \"skillId\": 1,\n  \"requiredCount\": 3\n}" },
            "url": "{{baseUrl}}/resource-requests"
          }
        },
        {
          "name": "Submit Request",
          "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/resource-requests/1/submit" }
        },
        {
          "name": "Approve Request",
          "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/resource-requests/1/approve" }
        }
      ]
    },
    {
      "name": "Allocations",
      "item": [
        {
          "name": "Allocate Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": 1,\n  \"projectId\": 1,\n  \"allocationPercent\": 60,\n  \"startDate\": \"2026-07-01\",\n  \"endDate\": \"2026-12-31\"\n}" },
            "url": "{{baseUrl}}/allocations"
          }
        },
        {
          "name": "List by Project",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/allocations/project/1" }
        }
      ]
    }
  ]
}
